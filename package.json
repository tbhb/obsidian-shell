{
  "name": "obsidian-shell",
  "version": "0.1.1-beta.2",
  "description": "Embedded xterm.js terminal backed by node-pty.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.22.0 <23",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "wdio run ./e2e/wdio.conf.mts",
    "check": "biome check . && eslint .",
    "check:fix": "biome check --write . && eslint --fix .",
    "depcruise:graph": "depcruise src test --output-type mermaid --output-to dependency-graph.mmd",
    "format": "biome format --write .",
    "format:markdown": "rumdl fmt .",
    "lint": "biome lint . && eslint .",
    "lint:actions": "actionlint",
    "lint:all": "pnpm run lint && pnpm run lint:deps && pnpm run lint:knip && pnpm run lint:markdown && pnpm run lint:yaml && pnpm run lint:spelling && pnpm run lint:actions && pnpm run lint:prose",
    "lint:deps": "depcruise src test",
    "lint:knip": "knip",
    "lint:markdown": "rumdl check .",
    "lint:markdown:fix": "rumdl check --fix .",
    "lint:prose": "vale --glob='!{.vale/**,node_modules/**,coverage/**,dist/**,test-results/**,CHANGELOG.md}' .",
    "lint:spelling": "cspell --no-progress --no-summary --gitignore .",
    "lint:staged": "nano-staged",
    "lint:yaml": "yamllint --strict .",
    "rebuild:native": "electron-rebuild --version 39.7.0 --only node-pty",
    "vale:sync": "vale sync"
  },
  "nano-staged": {
    "*.{ts,mts,tsx,js,mjs,cjs,jsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "src/**/*.{ts,mts,tsx}": [
      "eslint --fix --no-warn-ignored"
    ],
    "*.md": [
      "rumdl check --fix",
      "vale"
    ],
    "*.{yml,yaml}": "yamllint --strict",
    ".github/workflows/*.{yml,yaml}": "actionlint",
    "*.{ts,mts,tsx,js,mjs,cjs,jsx,json,jsonc,md,yml,yaml,css,html}": "cspell --no-progress --no-summary --no-must-find-files"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "cspell": "^9.7.0",
    "dependency-cruiser": "^17.3.10",
    "electron": "39.8.5",
    "eslint": "^9.30.1",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^26.0.0",
    "knip": "^6.6.2",
    "mocha": "^11.7.5",
    "nano-staged": "^1.0.2",
    "obsidian": "latest",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wdio-obsidian-reporter": "^3.0.2",
    "wdio-obsidian-service": "^3.0.2"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-obsidianmd>obsidian": "*"
      }
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
