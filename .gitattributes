# Normalize line endings: everyone sees LF on checkout; storage is LF.
* text=auto eol=lf

# Binary / generated files — never text-transform.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.map binary

# Don't count generated files toward GitHub language stats.
main.js linguist-generated=true
main.js.map linguist-generated=true
styles.css linguist-generated=true
styles.css.map linguist-generated=true
pnpm-lock.yaml linguist-generated=true
CHANGELOG.md linguist-generated=true

# Treat Vale style packages as vendored so they don't pollute language stats.
.vale/Google/** linguist-vendored=true
.vale/proselint/** linguist-vendored=true
.vale/write-good/** linguist-vendored=true
.vale/ai-tells/** linguist-vendored=true
.vale/ai-tells-commits/** linguist-vendored=true
.vale/ai-tells-experimental/** linguist-vendored=true
.vale/config/scripts/** linguist-vendored=true
