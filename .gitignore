# editors
.vscode
.idea
*.iml

# dependencies (pnpm-lock.yaml is committed)
node_modules

# Vale: ignore downloaded style packages, keep the project-specific style
# and vocabulary (these live under .vale/shell/ and
# .vale/config/vocabularies/shell/).
/.vale/*
!/.vale/shell/
!/.vale/config/
/.vale/config/*
!/.vale/config/vocabularies/
/.vale/config/vocabularies/*
!/.vale/config/vocabularies/shell/

# build output (published via GitHub releases, not committed).
# Anchored to repo root so they don't shadow `src/styles.css` etc.
/main.js
/main.js.map
/styles.css
/styles.css.map

# obsidian runtime data
data.json
# keep the fixture data.json under test/fixtures/ so integration tests can
# round-trip through a real `.obsidian/plugins/<id>/data.json` on disk.
!test/fixtures/**/data.json

# native-rebuild cache (HOME redirect from sandboxed builds)
.native-cache

# test output
coverage
/test-results
/e2e/.wdio-logs
/e2e/.tmp

# dependency-cruiser: on-demand mermaid graph output
/dependency-graph.mmd

# jscpd: on-demand report output (written when reporters include html, json, etc.)
/report/

# stryker: html report and sandbox tmp dir. The incremental report file
# (reports/stryker-incremental.json) is regenerated per run; CI restores it
# from cache, locally it's fine to discard.
/reports/
/.stryker-tmp/

# scratch dir for local notes, planning, drafts — kept out of cspell/knip/etc.
/tmp/

# logs
*.log
.pnpm-debug.log*

# husky wrappers — the hook files in .husky/ are committed, but the
# _/ subdirectory is regenerated by `pnpm install` via the prepare script.
.husky/_/

# os
.DS_Store
