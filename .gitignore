# editors
.vscode
.idea
*.iml

# dependencies (pnpm-lock.yaml is committed)
node_modules

# Vale: ignore downloaded style packages, keep the project-specific style
# and vocabulary (these live under .vale/obsidian-terminal/ and
# .vale/config/vocabularies/obsidian-terminal/).
/.vale/*
!/.vale/obsidian-terminal/
!/.vale/config/
/.vale/config/*
!/.vale/config/vocabularies/
/.vale/config/vocabularies/*
!/.vale/config/vocabularies/obsidian-terminal/

# build output (published via GitHub releases, not committed).
# Anchored to repo root so they don't shadow `src/styles.css` etc.
/main.js
/main.js.map
/styles.css
/styles.css.map

# obsidian runtime data
data.json

# native-rebuild cache (HOME redirect from sandboxed builds)
.native-cache

# test output
coverage

# logs
*.log
.pnpm-debug.log*

# husky wrappers — the hook files in .husky/ are committed, but the
# _/ subdirectory is regenerated by `pnpm install` via the prepare script.
.husky/_/

# os
.DS_Store
